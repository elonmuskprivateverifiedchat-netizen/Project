# Copy to .env and fill values for local development or deployment
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
PORT=3000
NODE_ENV=development
# ─────────────────────────────────────────────
#  XpressProFX / NeXTrade — Environment Config
# ─────────────────────────────────────────────

# ── General ──────────────────────────────────
NODE_ENV=production
PORT=8080
API_BASE_URL=https://api.yourdomain.com

# ── Database (Neon PostgreSQL) ───────────────
# Pooled connection (use for app queries via pgbouncer)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/xpressprofx?sslmode=require&pgbouncer=true
# Direct connection (use for migrations only)
DIRECT_URL=postgresql://user:password@ep-xxxx.neon.tech/xpressprofx?sslmode=require

# ── Authentication ───────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-256-bits
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_EXPIRES_IN=15m
SESSION_SECRET=change-me-strong-session-secret

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── SMTP Email ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM=XpressProFX <noreply@yourdomain.com>

# ── Payment Gateway ──────────────────────────
PAYMENT_GATEWAY_KEY=your-payment-gateway-api-key
PAYMENT_WEBHOOK_SECRET=your-webhook-signing-secret

# ── Admin ────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_ACCESS_CODE=your-admin-access-code

# ── Redis (optional — for session caching) ───
REDIS_URL=redis://localhost:6379

# ── Railway / VPS ────────────────────────────
RAILWAY_ENVIRONMENT=production

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ── Security ─────────────────────────────────
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=32-character-hex-encryption-key

# ── Google OAuth (optional) ──────────────────
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
